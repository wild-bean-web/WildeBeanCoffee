# Server environment variables
PORT=4000
# Use your Atlas SRV string here; replace user/pass/cluster placeholders.
MONGODB_URI=mongodb+srv://USER:PASS@YOUR-CLUSTER.mongodb.net/wildbeancoffee?retryWrites=true&w=majority
# Jest uses .env first, then .env.test (overrides). Tests use MONGODB_TEST_URI if set, else same host as MONGODB_URI with DB name wildbeancoffee_test.
# If you use .env.test, keep MONGODB_URI/MONGODB_TEST_URI in sync with working Atlas creds or remove stale keys.
# MONGODB_TEST_URI=mongodb+srv://USER:PASS@YOUR-CLUSTER.mongodb.net/wildbeancoffee_test?retryWrites=true&w=majority
MONGO_MAX_RETRIES=5
MONGO_RETRY_DELAY_MS=1000

# Store timezone for pickup-time vs business-hours validation (IANA e.g. America/New_York for MD). Optional; defaults to America/New_York.
# STORE_TIMEZONE=America/New_York

# Minimum minutes between order creation time and pickup (reject stale / too-soon slots). Optional; default 15. Match client NEXT_PUBLIC_PICKUP_MIN_LEAD_MINUTES in production.
# PICKUP_MIN_LEAD_MINUTES=15

# CORS Origin - Comma-separated list of allowed origins
# For development, use: http://localhost:3000
# For production, use your actual domain(s): https://yourdomain.com,https://www.yourdomain.com
# Note: Cannot use "*" when credentials are included in requests
CORS_ORIGIN=http://localhost:3000

# JWT Secret for authentication tokens
# Generate a random string (any long random string works)
# You can use: openssl rand -hex 32
# Or just use a long random string like: my-super-secret-key-12345-change-this
JWT_SECRET=your-secret-key-here-change-this-to-something-random

# Clover Payment Integration
# Get these from your Clover Merchant Dashboard > Account & Setup > Ecommerce API Tokens
# Private token (used as API key for server-side API calls)
CLOVER_API_KEY=your-clover-private-token-here
# Your Clover Merchant ID
CLOVER_MERCHANT_ID=your-clover-merchant-id-here
# Clover environment: 'sandbox' or 'production'
CLOVER_ENVIRONMENT=sandbox

# Email Configuration (for email verification)
# Option 1: Gmail (recommended for development)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
EMAIL_FROM=your-email@gmail.com

# Option 2: Custom SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=noreply@yourdomain.com

