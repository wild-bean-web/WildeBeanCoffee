# Client environment variables
# Update NEXT_PUBLIC_API_URL to match where the API is served.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Online Ordering Feature Flag
# Set to 'true' to enable online ordering/checkout, 'false' to disable
NEXT_PUBLIC_ONLINE_ORDERING_ENABLED=false

# Clover Payment Integration
# Your Clover Merchant ID (can be public)
NEXT_PUBLIC_CLOVER_MERCHANT_ID=your-clover-merchant-id-here
# Clover environment: 'sandbox' or 'production'
NEXT_PUBLIC_CLOVER_ENVIRONMENT=sandbox

