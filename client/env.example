# Client environment variables
# Update NEXT_PUBLIC_API_URL to match where the API is served.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Online Ordering Feature Flag
# Set to 'true' to enable online ordering/checkout, 'false' to disable
NEXT_PUBLIC_ONLINE_ORDERING_ENABLED=false

# Note: Hosted Checkout doesn't require any client-side Clover environment variables
# All Clover API calls are handled server-side

# Optional: minimum minutes from now until pickup (must match server PICKUP_MIN_LEAD_MINUTES)
# NEXT_PUBLIC_PICKUP_MIN_LEAD_MINUTES=15

